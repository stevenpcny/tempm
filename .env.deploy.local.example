# Deploy state — copy to .env.deploy.local and fill in values.
# This file is gitignored. Use it to resume or re-run deployments without losing state.

# Namecheap
NC_USER=
NC_API_KEY=

# Cloudflare
CF_EMAIL=
CF_API_KEY=
CF_ACCOUNT_ID=
ZONE_ID=

# Domain
DOMAIN=
NS1=
NS2=

# Worker
DATABASE_ID=
WORKER_URL=

# Frontend
VERCEL_URL=

# Admin (never commit the actual value — use `wrangler secret put ADMIN_PASSWORD` instead)
# ADMIN_PASSWORD=
